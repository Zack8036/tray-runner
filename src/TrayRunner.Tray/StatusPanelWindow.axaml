<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TrayRunner.Tray.StatusPanelWindow"
        Title="TrayRunner 狀態"
        Width="300"
        Height="284"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur, Blur"
        WindowStartupLocation="Manual">

    <!--
      毛玻璃外層:OS 原生模糊由 Window 的 TransparencyLevelHint 提供;此 Border 只負責
      圓角、細邊框與半透明 tint,疊在模糊之上模擬 frosted acrylic 質感。
      刻意不加 BoxShadow / Margin:無邊框透明視窗下,外擴的陰影會被視窗邊界裁掉,
      在底部留下一條突兀的暗邊;改以細邊框界定範圍即可。
      誠實邊界:這是近似,非 Apple 真正的 Liquid Glass(折射/鏡面高光需自寫 shader)。
      在此 Border 上按住拖曳可移動整個視窗(BeginMoveDrag)。
    -->
    <Border x:Name="RootBorder"
            CornerRadius="12"
            Padding="16"
            Background="#1FFFFFFF"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            PointerPressed="OnRootPointerPressed">
        <StackPanel Spacing="14">

            <TextBlock Text="系統狀態"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Opacity="0.85" />

            <!-- CPU 卡片 -->
            <Border CornerRadius="8"
                    Padding="12,10"
                    Background="#16FFFFFF">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="CPU" FontWeight="Medium" />
                        <TextBlock Grid.Column="1" x:Name="CpuPercentText"
                                   Text="--%" FontWeight="SemiBold" />
                    </Grid>
                    <ProgressBar x:Name="CpuBar" Minimum="0" Maximum="100" Value="0"
                                 Height="6" CornerRadius="3" />
                </StackPanel>
            </Border>

            <!-- 記憶體卡片 -->
            <Border CornerRadius="8"
                    Padding="12,10"
                    Background="#16FFFFFF">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="記憶體" FontWeight="Medium" />
                        <TextBlock Grid.Column="1" x:Name="MemPercentText"
                                   Text="--%" FontWeight="SemiBold" />
                    </Grid>
                    <ProgressBar x:Name="MemBar" Minimum="0" Maximum="100" Value="0"
                                 Height="6" CornerRadius="3" />
                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</Window>
